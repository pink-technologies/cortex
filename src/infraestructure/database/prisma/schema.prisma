// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AgentStatus {
  ACTIVE
  DEPRECATED
}

enum JobEventType {
  DONE
  ERROR
  STATUS
  TOKEN
  TOOL_CALL
  TOOL_RESULT
}

enum JobStatus {
  CANCELED
  COMPLETED
  FAILED
  QUEUED
  RUNNING
}

enum Role {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum ModelProviderType {
  OPENAI
  AZURE
  GEMINI
  CLAUDE
}

enum ConnectionRole {
  PRIMARY
  FALLBACK
  CLASSIFIER
}

enum SkillInstallationStatus {
  DISABLED
  ENABLED
}

enum SkillInstallationScopeType {
  GLOBAL
  USER
  WORKSPACE
}

enum SkillStatus {
  ARCHIVED
  ACTIVE
  DISABLED
  DRAFT
}

model Agent {
  id          String            @id @default(uuid())
  createdAt   DateTime          @default(now())
  description String?
  name        String
  status      AgentStatus       @default(ACTIVE)
  updatedAt   DateTime          @updatedAt
  agentSkills AgentSkill[]
  connections AgentConnection[]

  @@map("agent")
}

model AgentConnection {
  id                String         @id @default(uuid())
  agentId           String
  modelConnectionId String
  role              ConnectionRole @default(PRIMARY)
  isDefault         Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  agent           Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  modelConnection ModelConnection @relation(fields: [modelConnectionId], references: [id], onDelete: Cascade)

  @@unique([agentId, modelConnectionId])
  @@index([agentId])
  @@index([modelConnectionId])
  @@map("agent_model_connection")
}

model AgentSkill {
  id        String   @id @default(uuid())
  agentId   String
  skillId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id])
  skill Skill @relation(fields: [skillId], references: [id])

  @@unique([agentId, skillId])
  @@map("agent_skill")
}

model Chat {
  id        String   @id @default(uuid())
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]
  jobs     Job[]

  @@map("chat")
}

model Message {
  id        String   @id @default(uuid())
  chatId    String
  role      Role
  content   String
  createdAt DateTime @default(now())

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  jobId String?
  job   Job?    @relation("JobMessages", fields: [jobId], references: [id])

  triggeredByJobs Job[] @relation("TriggerMessage")
  resultOfJobs    Job[] @relation("ResultMessage")

  @@index([chatId])
  @@map("message")
}

model Job {
  id               String    @id @default(uuid())
  chatId           String
  triggerMessageId String?
  status           JobStatus @default(QUEUED)
  resultMessageId  String?
  error            String?

  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  triggerMessage Message? @relation("TriggerMessage", fields: [triggerMessageId], references: [id])
  resultMessage  Message? @relation("ResultMessage", fields: [resultMessageId], references: [id])

  messages Message[]  @relation("JobMessages")
  events   JobEvent[]

  @@index([chatId])
  @@index([status])
  @@map("job")
}

model JobEvent {
  id        String       @id @default(uuid())
  jobId     String
  type      JobEventType
  payload   Json
  createdAt DateTime     @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("job_event")
}

model Model {
  id              String   @id @default(uuid())
  slug            String
  name            String
  description     String?
  modelProviderId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  modelProvider    ModelProvider     @relation(fields: [modelProviderId], references: [id], onDelete: Cascade)
  modelConnections ModelConnection[]

  @@unique([slug])
  @@index([modelProviderId])
  @@map("model")
}

model ModelConnection {
  id        String   @id @default(uuid())
  modelId   String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  model       Model             @relation(fields: [modelId], references: [id], onDelete: Cascade)
  connections AgentConnection[]

  @@index([modelId])
  @@map("model_connection")
}

model ModelProvider {
  id          String            @id @default(uuid())
  slug        String
  name        String
  description String?
  type        ModelProviderType
  config      Json
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  models      Model[]

  @@unique([slug])
  @@map("model_provider")
}

model Skill {
  id          String      @id @default(uuid())
  slug        String      @unique
  name        String
  description String?
  status      SkillStatus @default(ACTIVE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  installations              SkillInstallation[]
  agentSkills                AgentSkill[]
  skillDatasourceConnections SkillDatasourceConnection[]
  skillTools                 SkillTool[]

  @@map("skill")
}

enum DatasourceAuthType {
  NONE
  API_KEY
  EMAIL_PASSWORD
  USERNAME_PASSWORD
  TOKEN

  @@map("datasource_auth_type")
}

model DatasourceProvider {
  id                    String                 @id @default(uuid())
  slug                  String
  name                  String
  description           String?
  authType              DatasourceAuthType     @default(NONE)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  datasourceConnections DatasourceConnection[]

  @@unique([slug])
  @@map("datasource_provider")
}

model DatasourceConnection {
  id          String   @id @default(uuid())
  slug        String
  name        String
  description String?
  providerId  String
  config      Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  provider                   DatasourceProvider          @relation(fields: [providerId], references: [id], onDelete: Cascade)
  skillDatasourceConnections SkillDatasourceConnection[]

  @@unique([slug])
  @@index([providerId])
  @@map("datasource_connection")
}

model SkillDatasourceConnection {
  id           String   @id @default(uuid())
  skillId      String
  connectionId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  skill      Skill                @relation(fields: [skillId], references: [id], onDelete: Cascade)
  connection DatasourceConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([skillId, connectionId])
  @@map("skill_connection")
}

model Tool {
  id           String        @id @default(uuid())
  slug         String
  name         String
  description  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  toolVersions ToolVersion[]
  skillTools   SkillTool[]

  @@unique([slug])
  @@map("tool")
}

model ToolVersion {
  id        String   @id @default(uuid())
  toolId    String
  version   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([toolId, version])
  @@map("tool_version")
}

model SkillTool {
  id        String   @id @default(uuid())
  skillId   String
  toolId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)
  tool  Tool  @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([skillId, toolId])
  @@map("skill_tool")
}

model SkillInstallation {
  id               String                     @id @default(uuid())
  skillId          String
  scopeType        SkillInstallationScopeType
  scopeId          String
  installationPath String?
  status           SkillInstallationStatus    @default(ENABLED)
  config           Json?
  installedBy      String?
  installedAt      DateTime                   @default(now())
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([scopeType, scopeId, skillId])
  @@index([scopeType, scopeId])
  @@map("skill_installation")
}
