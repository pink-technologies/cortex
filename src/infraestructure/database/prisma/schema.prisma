// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum PermissionScope {
  ORGANIZATION
}

enum PermissionStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum PermissionCategory {
  GLOBAL
  SYSTEM
}

enum RoleType {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum RoleStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING_CONFIRMATION
}

model Invitation {
  id             String    @id @default(uuid())
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())
  email          String
  expiresAt      DateTime?
  invitedById    String?
  organizationId String
  revokedAt      DateTime?
  roleId         String?
  status         InvitationStatus
  token          String      @unique
  updatedAt      DateTime?    @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User?             @relation(fields: [invitedById], references: [id], onDelete: SetNull)
  role         OrganizationRole? @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([email, organizationId])
  @@map("invitations")
}

model User {
  id                 String                @id @default(uuid())
  createdAt          DateTime              @default(now())
  cognitoSub         String?
  deletedAt          DateTime?
  email              String
  firstName          String
  lastName           String
  profile            UserProfile?
  status             UserStatus
  updatedAt          DateTime              @updatedAt

  organizationMemberships OrganizationMembership[]
  invitationsSent        Invitation[]

  @@unique([email], where: { deletedAt: null })
  @@unique([cognitoSub], where: { deletedAt: null })
  @@index([deletedAt])
  @@map("users")
}

model UserProfile {
  id          String      @id @default(uuid())
  createdAt    DateTime   @default(now())
  deletedAt    DateTime?
  locale       String?
  profilePictureUrl String?
  phoneNumber  String?
  phoneVerifiedAt DateTime?
  timezone     String?
  userId       String
  updatedAt    DateTime?  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@unique([phoneNumber], where: { deletedAt: null })
  @@map("user_profiles")
}

model Organization {
  id                  String                @id @default(uuid())
  createdAt           DateTime             @default(now())
  deletedAt           DateTime?
  name                String
  slug                String
  profile OrganizationProfile?
  status OrganizationStatus
  updatedAt           DateTime?             @updatedAt

  memberships  OrganizationMembership[]
  invitations  Invitation[]

  @@unique([slug], where: { deletedAt: null })
  @@index([deletedAt])
  @@map("organizations")
}

model OrganizationProfile {
  id     String    @id @default(uuid())
  createdAt DateTime @default(now())
  deletedAt DateTime?
  logoUrl String?
  organizationId String
  updatedAt DateTime? @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId])
  @@map("organization_profiles")
}

model OrganizationMembership {
  id              String @id @default(uuid())
  createdAt       DateTime @default(now())
  joinedAt        DateTime?
  organizationId  String
  roleId          String
  status          MembershipStatus
  userId          String
  updatedAt       DateTime? @updatedAt

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization  Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role          OrganizationRole @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
  @@map("organization_memberships")
}

model OrganizationRole {
  id          String     @id @default(uuid())
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?
  key         String
  status      RoleStatus
  type        RoleType
  updatedAt   DateTime? @updatedAt
  
  members      OrganizationMembership[]
  permissions  OrganizationRolePermission[]
  invitations  Invitation[]

  @@unique([key], where: { deletedAt: null })
  @@map("organization_roles")
}

model OrganizationRolePermission {
  id           String   @id @default(uuid())
  assignedAt   DateTime @default(now())
  permissionId String
  roleId       String
  updatedAt    DateTime? @updatedAt

  role       OrganizationRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission       @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("organization_role_permissions")
}

model Permission {
  id          String           @id @default(uuid())
  category    PermissionCategory @default(GLOBAL)
  createdAt   DateTime        @default(now())
  deletedAt   DateTime?
  description String
  name        String
  key         String
  scope       PermissionScope
  status      PermissionStatus
  updatedAt   DateTime? @updatedAt
  
  organizationRolePermissions OrganizationRolePermission[]

  @@unique([key], where: { deletedAt: null })
  @@index([scope])
  @@map("permissions")
}
